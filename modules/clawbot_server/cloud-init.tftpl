#cloud-config
package_update: true
package_upgrade: true
packages:
  - podman
  - systemd-container
  - dbus
  - ca-certificates
  - curl
  - git
  - htop
  - tmux
  - auditd
  - fail2ban
  - unattended-upgrades

users:
%{ for user in users ~}
  - name: ${user}
    shell: /bin/bash
    groups: [sudo]
    lock_passwd: true
    sudo:
      - "ALL=(ALL) NOPASSWD:ALL"
%{ if length(lookup(user_ssh_authorized_keys, user, [])) > 0 ~}
    ssh_authorized_keys:
%{ for key in lookup(user_ssh_authorized_keys, user, []) ~}
      - ${key}
%{ endfor ~}
%{ endif ~}
%{ endfor ~}

ssh_pwauth: false
disable_root: %{ if enable_root_ssh }false%{ else }true%{ endif }

write_files:
  - path: /etc/ssh/sshd_config.d/99-clawbot-hardening.conf
    owner: root:root
    permissions: '0644'
    content: |
      # SSH hardening
      ChallengeResponseAuthentication no
      KbdInteractiveAuthentication no
      PasswordAuthentication no
      PermitEmptyPasswords no
      PermitRootLogin %{ if enable_root_ssh }yes%{ else }no%{ endif }
      PubkeyAuthentication yes
      LoginGraceTime 30
      MaxAuthTries 4
      MaxSessions 3
      IgnoreRhosts yes
      HostbasedAuthentication no
      PermitUserEnvironment no
      UseDNS no
      AllowAgentForwarding no
      X11Forwarding no
      AllowTcpForwarding yes
      DisableForwarding no
      ClientAliveInterval 300
      ClientAliveCountMax 2
      Compression no

  - path: /etc/fail2ban/jail.d/sshd.local
    owner: root:root
    permissions: '0644'
    content: |
      [sshd]
      enabled = true
      mode = aggressive
      port = ssh
      logpath = /var/log/auth.log
      maxretry = 5
      findtime = 10m
      bantime = 6h

  - path: /etc/apt/apt.conf.d/20auto-upgrades
    owner: root:root
    permissions: '0644'
    content: |
      APT::Periodic::Update-Package-Lists "1";
      APT::Periodic::Download-Upgradeable-Packages "1";
      APT::Periodic::AutocleanInterval "7";
      APT::Periodic::Unattended-Upgrade "1";

  - path: /etc/apt/apt.conf.d/50unattended-upgrades
    owner: root:root
    permissions: '0644'
    content: |
      Unattended-Upgrade::Origins-Pattern {
        "origin=Ubuntu,archive=stable,label=Ubuntu";
      };
      Unattended-Upgrade::Package-Blacklist {};
      Unattended-Upgrade::Automatic-Reboot "false";
      Unattended-Upgrade::Mail "root";

  - path: /etc/sysctl.d/99-clawbot-hardening.conf
    owner: root:root
    permissions: '0644'
    content: |
      kernel.kptr_restrict = 2
      kernel.randomize_va_space = 2
      fs.protected_hardlinks = 1
      fs.protected_symlinks = 1
      fs.protected_fifos = 1
      fs.protected_regular = 1
      fs.suid_dumpable = 0
      kernel.yama.ptrace_scope = 1
      net.ipv4.conf.all.rp_filter = 1
      net.ipv4.conf.default.rp_filter = 1
      net.ipv4.tcp_syncookies = 1

  - path: /etc/audit/rules.d/99-clawbot.rules
    owner: root:root
    permissions: '0644'
    content: |
      -w /etc/sudoers -p wa -k sudoers_changes
      -w /etc/sudoers.d -p wa -k sudoers_changes
      -w /etc/passwd -p wa -k identity
      -w /etc/shadow -p wa -k identity
      -w /etc/group -p wa -k identity
      -w /etc/gshadow -p wa -k identity
      -w /var/log/auth.log -p wa -k auth
      -w /etc/ssh/sshd_config -p wa -k sshd_config

  - path: /home/openclaw/.config/containers/systemd/openclaw.container
    owner: root:root
    permissions: '0644'
    content: |
      [Unit]
      Description=OpenClaw gateway (rootless Podman)

      [Container]
      Image=localhost/openclaw:local
      ContainerName=openclaw
      UserNS=keep-id
      Notify=no

      Volume=/opt/clawbot/config:/config
      Volume=/opt/clawbot/work:/workspace
      Volume=/opt/clawbot/state:/state

      EnvironmentFile=/opt/clawbot/config/.env
      Environment=OPENCLAW_CONFIG_PATH=/config/openclaw.json
      Environment=OPENCLAW_HOME=/state
      Environment=OPENCLAW_WORKSPACE_DIR=/workspace
      Environment=TERM=xterm-256color
      EnvironmentFile=-/config/secrets/llm.env

      PublishPort=127.0.0.1:18789:18789
      PublishPort=127.0.0.1:18790:18790

      Pull=never
      Exec=node dist/index.js gateway --bind lan --port 18789

      [Service]
      TimeoutStartSec=300
      Restart=on-failure

      [Install]
      WantedBy=default.target

  - path: /usr/local/bin/openclaw-bootstrap-fetch
    owner: root:root
    permissions: '0755'
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      destination="/usr/local/bin/openclaw-node-bootstrap-runner"
      if [ "$#" -gt 0 ] && [ -n "$1" ]; then
        destination="$1"
      fi
      attempts="$${OPENCLAW_BOOTSTRAP_FETCH_ATTEMPTS:-6}"
      timeout="$${OPENCLAW_BOOTSTRAP_FETCH_TIMEOUT:-30}"
      wait_seconds="$${OPENCLAW_BOOTSTRAP_FETCH_RETRY_SECONDS:-4}"

      if [ -z "$${OPENCLAW_BOOTSTRAP_RUNNER_URL:-}" ]; then
        echo "OPENCLAW_BOOTSTRAP_RUNNER_URL is not set." >&2
        exit 1
      fi

      log_msg() {
        printf '[%s] [openclaw-bootstrap-fetch] %s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" "$1"
      }

      retry_fetch() {
        attempt=1
        while [ "$attempt" -le "$attempts" ]; do
          if command -v curl >/dev/null 2>&1; then
            log_msg "Attempt $attempt/$attempts: fetching with curl from $${OPENCLAW_BOOTSTRAP_RUNNER_URL}"
            if curl --retry 2 --max-time "$${timeout}" -fSL "$${OPENCLAW_BOOTSTRAP_RUNNER_URL}" -o "$destination"; then
              return 0
            fi
          elif command -v wget >/dev/null 2>&1; then
            log_msg "Attempt $attempt/$attempts: fetching with wget from $${OPENCLAW_BOOTSTRAP_RUNNER_URL}"
            if wget --timeout="$${timeout}" -O "$destination" "$${OPENCLAW_BOOTSTRAP_RUNNER_URL}"; then
              return 0
            fi
          else
            echo "Missing curl/wget for bootstrap fetch." >&2
            return 1
          fi

          log_msg "Fetch attempt $attempt failed."
          sleep "$wait_seconds"
          attempt=$((attempt + 1))
        done
        return 1
      }

      if ! retry_fetch; then
        echo "Failed to fetch bootstrap runner from OPENCLAW_BOOTSTRAP_RUNNER_URL=$${OPENCLAW_BOOTSTRAP_RUNNER_URL}" >&2
        exit 1
      fi

      if [ ! -s "$destination" ]; then
        echo "Fetched bootstrap runner file is empty: $${OPENCLAW_BOOTSTRAP_RUNNER_URL}" >&2
        exit 1
      fi

      chmod 0755 "$destination"

runcmd:
  - |
    OPENCLAW_BOOTSTRAP_RUNNER_URL='${openclaw_bootstrap_runner_url}'
    OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH='/opt/clawbot/bootstrap/openclaw-node-bootstrap-runner.sh'
    if [ -n "$${OPENCLAW_BOOTSTRAP_RUNNER_URL}" ]; then
      if ! OPENCLAW_BOOTSTRAP_RUNNER_URL="$OPENCLAW_BOOTSTRAP_RUNNER_URL" \
        /usr/local/bin/openclaw-bootstrap-fetch; then
        echo "Failed to fetch bootstrap runner from OPENCLAW_BOOTSTRAP_RUNNER_URL=$OPENCLAW_BOOTSTRAP_RUNNER_URL" >&2
        if [ -x "$OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH" ]; then
          echo "Using cached bootstrap runner from $OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH"
          cp -p "$OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH" /usr/local/bin/openclaw-node-bootstrap-runner
          chmod 0755 /usr/local/bin/openclaw-node-bootstrap-runner
        fi
      fi
    fi

    OPENCLAW_REPO_URL='${openclaw_repo_url}'
    OPENCLAW_IMAGE='localhost/openclaw:local'
    OPENCLAW_GATEWAY_TOKEN='${openclaw_gateway_token}'
    OPENCLAW_REQUIRE_OPT_VOLUME='${openclaw_opt_volume_enabled}'
    OPENCLAW_OPT_VOLUME_FSTYPE='${openclaw_opt_volume_fstype}'
    OPENCLAW_OPT_VOLUME_ID='${openclaw_opt_volume_id}'
    OPENCLAW_OPT_VOLUME_NAME='${openclaw_opt_volume_name}'
    OPENCLAW_OPT_VOLUME_WAIT_SECONDS=300
    OPENCLAW_AGENT_FLEET_TEMPLATE_B64='${openclaw_agent_fleet_template}'
    OPENCLAW_ORCHESTRATOR_POLICY_TEMPLATE_B64='${openclaw_orchestrator_policy_template}'
    OPENCLAW_STACKS_TEMPLATE_B64='${openclaw_stacks_template}'
    OPENCLAW_JENNIFER_TEMPLATE_B64='${openclaw_jennifer_template}'
    OPENCLAW_STEVE_TEMPLATE_B64='${openclaw_steve_template}'
    OPENCLAW_BUSINESS_TEMPLATE_B64='${openclaw_business_template}'
    OPENCLAW_LLM_TEMPLATE_B64='${openclaw_llm_template}'
    OPENCLAW_PUBLIC_HOSTNAME='${openclaw_public_hostname}'
    OPENCLAW_LETSENCRYPT_EMAIL='${openclaw_letsencrypt_email}'
    OPENCLAW_ENABLE_WEBHOOK_PROXY='${openclaw_enable_webhook_proxy}'
    OPENCLAW_WEBHOOK_RECEIVER_PORT='${openclaw_webhook_receiver_port}'
    export OPENCLAW_REPO_URL OPENCLAW_IMAGE OPENCLAW_GATEWAY_TOKEN OPENCLAW_REQUIRE_OPT_VOLUME \
      OPENCLAW_OPT_VOLUME_FSTYPE OPENCLAW_OPT_VOLUME_ID OPENCLAW_OPT_VOLUME_NAME \
      OPENCLAW_OPT_VOLUME_WAIT_SECONDS OPENCLAW_AGENT_FLEET_TEMPLATE_B64 OPENCLAW_ORCHESTRATOR_POLICY_TEMPLATE_B64 \
      OPENCLAW_STACKS_TEMPLATE_B64 OPENCLAW_JENNIFER_TEMPLATE_B64 OPENCLAW_STEVE_TEMPLATE_B64 \
      OPENCLAW_BUSINESS_TEMPLATE_B64 OPENCLAW_LLM_TEMPLATE_B64 OPENCLAW_PUBLIC_HOSTNAME \
      OPENCLAW_LETSENCRYPT_EMAIL OPENCLAW_ENABLE_WEBHOOK_PROXY OPENCLAW_WEBHOOK_RECEIVER_PORT

    if [ "$${OPENCLAW_ENABLE_WEBHOOK_PROXY}" = "true" ]; then
      if [ -z "$${OPENCLAW_PUBLIC_HOSTNAME}" ] || [ -z "$${OPENCLAW_LETSENCRYPT_EMAIL}" ]; then
        echo "OPENCLAW_ENABLE_WEBHOOK_PROXY is true, but OPENCLAW_PUBLIC_HOSTNAME and OPENCLAW_LETSENCRYPT_EMAIL are required." >&2
        exit 1
      fi
      if ! printf '%s' "$${OPENCLAW_LETSENCRYPT_EMAIL}" | grep -Eq '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$'; then
        echo "OPENCLAW_LETSENCRYPT_EMAIL does not look valid: $${OPENCLAW_LETSENCRYPT_EMAIL}" >&2
        exit 1
      fi
    fi

    if [ ! -x /usr/local/bin/openclaw-node-bootstrap-runner ]; then
%{ if openclaw_bootstrap_runner_script != "" ~}
      printf '%s' '${openclaw_bootstrap_runner_script}' | base64 -d | gzip -dc > /usr/local/bin/openclaw-node-bootstrap-runner
      chmod 0755 /usr/local/bin/openclaw-node-bootstrap-runner
%{ else ~}
      echo "Failed to fetch bootstrap runner from OPENCLAW_BOOTSTRAP_RUNNER_URL, no backup/cached runner exists, and no embedded fallback script was provided." >&2
      exit 1
%{ endif ~}
    fi

    /usr/local/bin/openclaw-node-bootstrap-runner

    if [ -x /usr/local/bin/openclaw-node-bootstrap-runner ]; then
      mkdir -p /opt/clawbot/bootstrap
      cp -p /usr/local/bin/openclaw-node-bootstrap-runner "$OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH"
      chmod 0755 "$OPENCLAW_BOOTSTRAP_RUNNER_BACKUP_PATH"
    fi
